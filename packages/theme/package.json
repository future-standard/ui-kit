{
  "name": "@future-standard/theme",
  "version": "0.0.0",
  "type": "module",
  "sideEffects": ["**/*.css"],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./style.css": "./dist/index.css"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --emitDeclarationOnly"
  },
  "devDependencies": {
    "@future-standard/build-config": "workspace:*",
    "typescript": "5.9.3",
    "vite": "8.0.0"
  }
}
